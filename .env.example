# Development fallback only. Public users should prefer `kr-elections-mcp setup-key`
# or set NEC_API_KEY_DECODED / NEC_API_KEY_ENCODED in their MCP client environment.
# If you intentionally use this file, load it explicitly with `--env-file .env`.
# If only NEC_API_KEY_DECODED is set, the server derives the encoded variant automatically
# and still tries decoded first, then encoded.
# NEC_API_KEY remains as a legacy single-key fallback.
NEC_API_KEY_DECODED=your_decoded_service_key
NEC_API_KEY_ENCODED=your_encoded_service_key
# NEC_API_KEY=your_service_key
NEC_API_BASE_URL=https://apis.data.go.kr/9760000
NEC_RESULT_FORMAT=json
REQUEST_TIMEOUT_SECONDS=20
RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=1.0
CACHE_DIR=.cache/http
CACHE_TTL_SECONDS=3600
KRPOLTEXT_BASE_URL=https://taehyun-lim.github.io/krpoltext/data
# KRPOLTEXT_CAMPAIGN_BOOKLET_URL=https://osf.io/download/6ybj8/
LOG_LEVEL=INFO
USER_AGENT=kr-elections-mcp/0.1

